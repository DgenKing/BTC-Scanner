# BTC Scanner Configuration
# Edit settings here - all values are read by the scanner at runtime.
# Timeframe options: 1m 3m 5m 15m 30m 1h 2h 4h 6h 8h 12h 1d

[SETTINGS]
MIN_TIMEFRAME = 1h

[RSI]
RSI_OVERSOLD = 37
RSI_OVERBOUGHT = 63
RSI_PERIOD = 14
RSI_LOOKBACK = 10

[MACD]
MACD_FAST = 12
MACD_SLOW = 26
MACD_SIGNAL = 9
MACD_CROSS_LOOKBACK = 23
REQUIRE_MACD_CROSSOVER = True

[TREND_FILTER]
TREND_FILTER_ENABLED = True
EMA_FAST = 50
EMA_SLOW = 200
TREND_WEIGHT = 2.0
COOLDOWN_CANDLES = 12

[SUPPORT_RESISTANCE]
SUPPORT_LOOKBACK = 250
RESISTANCE_LOOKBACK = 250
SR_TOLERANCE_PCT = 0.5
MIN_SR_TOUCHES = 3
VOLUME_MULTIPLIER = 2.5

[FIBONACCI]
FIB_ZONES = 0.382, 0.5, 0.618, 0.786
FIB_TOLERANCE_PCT = 0.5

[VOLUME_PROFILE]
VP_ENABLED = True
VP_LOOKBACK = 120
NUM_BINS = 48
HVN_MULTIPLIER = 2.0
HVN_TOLERANCE_PCT = 0.5
REQUIRE_HVN = True

[CONFLUENCE]
REQUIRE_ALL_CONFIRMATIONS = True
MIN_CONFIRMATIONS = 3
LONG_THRESHOLD = 5
SHORT_THRESHOLD = -5.0
HIGH_CONFIDENCE = 8
MEDIUM_CONFIDENCE = 5
RSI_WEIGHT = 2.0
MACD_WEIGHT = 2.5
SR_WEIGHT = 2.5
FIB_WEIGHT = 2.0
VP_WEIGHT = 2.5
SENTIMENT_WEIGHT = 2.0

[TRADING]
ENTRY_LONG_WINDOW = any
ENTRY_SHORT_WINDOW = any
EXIT_DAY = any

[SENTIMENT_SOURCES]
# Twitter/X sentiment from real tweets (FREE, twscrape required)
# Setup: pip install twscrape
TWITTER_ENABLED = False
TWITTER_WEIGHT = 2.0

# cryptocurrency.cv API (FREE, no API key, real market volume)
CRYPTO_CV_ENABLED = True
CRYPTO_CV_WEIGHT = 1.5

# DuckDuckGo fallback sentiment (always available, basic)
DUCKDUCKGO_ENABLED = True
DUCKDUCKGO_WEIGHT = 0.5

[AI]
# Get your DeepSeek API key at: https://platform.deepseek.com
DEEPSEEK_API_KEY = YOUR_DEEPSEEK_API_KEY_HERE

[MINIMAX]
# Get your MiniMax API key at: https://platform.minimax.io
MINIMAX_API_KEY = YOUR_MINIMAX_API_KEY_HERE
MINIMAX_MODEL = MiniMax-M2.5

[PAPER_TRADING]
PAPER_TRADING_ENABLED = False
PAPER_STARTING_BALANCE = 10000
PAPER_POSITION_SIZE_PCT = 10
PAPER_MAX_POSITIONS = 1
PAPER_DEFAULT_SL_PCT = 2.0
PAPER_DEFAULT_TP_PCT = 4.0
TRAILING_STOP_PCT = 0
PAPER_STATE_FILE = paper_trades.json
